# Build artifacts
*.zip
*.tar.gz
release/

# Session artifacts
handoff/
.omc/

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# IDE
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db

# Module runtime files (should not be in repo)
common/tmp/
common/bin/keygen

# WebUI build cache
webui/assets/*.map

# WebUI dev source (not shipped)
webui-mockup/

# Logs
*.log

# Native build source (binaries in bin/ are tracked)
native/

# Rust build artifacts
rust/target/
bin/arm64-v8a/ta-enhanced
bin/armeabi-v7a/ta-enhanced

# WebUI build
webui/node_modules/
webui/dist/

# MCP / Claude dev tooling
.claude/
.mcp.json
.mcp-vector-search/
vectors.db*

# Credentials
*.pem
*.key
*.jks
*.keystore
# Public trust anchors are not credentials — they ship in the binary.
!rust/src/keybox/roots/*.pem
.env
.env.*
